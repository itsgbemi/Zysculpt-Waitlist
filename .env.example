# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ZEPTOMAIL_API_KEY: Required for sending emails via ZeptoMail.
ZEPTOMAIL_API_KEY="YOUR_ZEPTOMAIL_TOKEN"

# ZEPTOMAIL_SENDER_EMAIL: The email address to send from (must be verified in ZeptoMail).
ZEPTOMAIL_SENDER_EMAIL="noreply@zysculpt.com"

# ZEPTOMAIL_SENDER_NAME: The name to display as the sender.
ZEPTOMAIL_SENDER_NAME="Zysculpt Team"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: The service role key for server-side operations (bypasses RLS).
# WARNING: Keep this secret! Do not expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
